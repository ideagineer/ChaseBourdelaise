{
  "version": 2,
  "builds": [
    { "src": "api/send-report.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/send-report", "dest": "/api/send-report.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "functions": {
    "api/send-report.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
